def get_books(filename):
    with open(filename, 'r', encoding='utf-8') as f:
        data = f.readlines()[1:]
        
    parse = lambda line: [
        line.split('|')[0], 
        line.split('|')[1], 
        line.split('|')[2], 
        int(line.split('|')[3]), 
        float(line.split('|')[4])
    ]
    
    return list(map(parse, filter(str.strip, data)))
